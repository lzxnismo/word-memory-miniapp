/* pages/stats-stats/stats.wxss */
.container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background-color: #f5f7fa;
}

.header-section {
  padding: 40rpx 30rpx 30rpx;
  background-color: white;
  border-bottom-left-radius: 30rpx;
  border-bottom-right-radius: 30rpx;
}

.page-title {
  font-size: 48rpx;
  font-weight: bold;
  color: #667eea;
}

/* 总览卡片 */
.overview-card {
  margin: 30rpx;
  padding: 40rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 30rpx;
  box-shadow: 0 12rpx 32rpx rgba(102, 126, 234, 0.3);
  text-align: center;
}

.streak-info {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 40rpx;
}

.streak-icon {
  font-size: 64rpx;
}

.streak-num {
  font-size: 72rpx;
  font-weight: bold;
  color: white;
  margin: 0 20rpx;
}

.streak-text {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
}

.big-stats {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20rpx;
}

.stat-item {
  background-color: rgba(255, 255, 255, 0.2);
  padding: 20rpx;
  border-radius: 16rpx;
}

.stat-value {
  display: block;
  font-size: 48rpx;
  font-weight: bold;
  color: white;
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

/* 通用区块 */
.section {
  padding: 0 30rpx 30rpx;
}

.section-header {
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

/* 趋势图表 */
.trend-chart {
  display: flex;
  align-items: flex-end;
  justify-content: space-around;
  padding: 30rpx 20rpx;
  background-color: white;
  border-radius: 20rpx;
  min-height: 300rpx;
}

.chart-bar-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 12%;
}

.chart-bar-wrapper {
  transform-origin: bottom;
}

.day-name {
  font-size: 22rpx;
  color: #999;
  margin-top: 16rpx;
}

.day-count {
  font-size: 20rpx;
  color: #667eea;
  margin-top: 8rpx;
}

/* 详细数据列表 */
.detail-list {
  background-color: white;
  border-radius: 20rpx;
  overflow: hidden;
}

.detail-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #eee;
}

.detail-row:last-child {
  border-bottom: none;
}

.detail-label {
  font-size: 28rpx;
  color: #666;
}

.detail-value {
  font-size: 32rpx;
  font-weight: bold;
  color: #667eea;
}

/* 成就徽章 */
.badge-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}

.badge-item {
  padding: 30rpx 20rpx;
  background-color: white;
  border-radius: 16rpx;
  text-align: center;
  opacity: 0.5;
  transition: all 0.3s;
}

.badge-item.unlocked {
  opacity: 1;
  box-shadow: 0 4rpx 12rpx rgba(102, 126, 234, 0.2);
}

.badge-icon {
  display: block;
  font-size: 64rpx;
  margin-bottom: 12rpx;
}

.badge-name {
  display: block;
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}

.badge-desc {
  display: block;
  font-size: 20rpx;
  color: #999;
}
