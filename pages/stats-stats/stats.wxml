<!-- pages/stats-stats/stats.wxml -->
<view class="container">
  <view class="header-section">
    <text class="page-title">📊 学习统计</text>
  </view>

  <!-- 总览卡片 -->
  <view class="overview-card">
    <view class="streak-info">
      <text class="streak-icon">🔥</text>
      <text class="streak-num">{{currentStreak}}</text>
      <text class="streak-text">天连续学习</text>
    </view>
    
    <view class="big-stats">
      <view class="stat-item">
        <text class="stat-value">{{totalWordsLearned}}</text>
        <text class="stat-label">已学单词</text>
      </view>
      <view class="stat-item">
        <text class="stat-value">{{masteredWords}}</text>
        <text class="stat-label">已掌握</text>
      </view>
      <view class="stat-item">
        <text class="stat-value">{{accuracy}}%</text>
        <text class="stat-label">正确率</text>
      </view>
    </view>
  </view>

  <!-- 学习趋势图表 -->
  <view class="section">
    <view class="section-header">
      <text class="section-title">📈 学习趋势（最近 7 天）</text>
    </view>
    
    <view class="trend-chart">
      <view class="chart-bar-container" wx:for="{{weeklyData}}" wx:key="index">
        <view class="chart-bar-wrapper">
          <slider 
            value="{{item.count / maxWeekCount}}" 
            show-value 
            orientation="vertical"
            block-size="12"
            activeColor="#667eea"
            backgroundColor="#e0e0e0"
            style="height:{{(item.count / maxWeekCount * 200)}}rpx"
          />
        </view>
        <text class="day-name">{{item.day}}</text>
        <text class="day-count">{{item.count}}词</text>
      </view>
    </view>
  </view>

  <!-- 详细统计 -->
  <view class="section">
    <view class="section-header">
      <text class="section-title">💡 详细数据</text>
    </view>
    
    <view class="detail-list">
      <view class="detail-row">
        <text class="detail-label">总复习次数</text>
        <text class="detail-value">{{totalReviews}}</text>
      </view>
      <view class="detail-row">
        <text class="detail-label">平均记忆时长</text>
        <text class="detail-value">{{avgDuration}}秒</text>
      </view>
      <view class="detail-row">
        <text class="detail-label">最长连击记录</text>
        <text class="detail-value">{{longestStreak}}天</text>
      </view>
    </view>
  </view>

  <!-- 成就徽章 -->
  <view class="section">
    <view class="section-header">
      <text class="section-title">🏆 成就徽章</text>
    </view>
    
    <view class="badge-grid">
      <view class="badge-item {{isBadgeUnlocked.morning ? 'unlocked' : ''}}">
        <text class="badge-icon">🌅</text>
        <text class="badge-name">早起鸟</text>
        <text class="badge-desc">早晨 6 点前学习</text>
      </view>
      
      <view class="badge-item {{isBadgeUnlocked.consistent ? 'unlocked' : ''}}">
        <text class="badge-icon">🔥</text>
        <text class="badge-name">坚持之星</text>
        <text class="badge-desc">连续学习 7 天</text>
      </view>
      
      <view class="badge-item {{isBadgeUnlocked.master ? 'unlocked' : ''}}">
        <text class="badge-icon">⭐</text>
        <text class="badge-name">词汇达人</text>
        <text class="badge-desc">掌握 500+ 单词</text>
      </view>
      
      <view class="badge-item {{isBadgeUnlocked.perfect ? 'unlocked' : ''}}">
        <text class="badge-icon">🎯</text>
        <text class="badge-name">完美主义</text>
        <text class="badge-desc">正确率 90%+</text>
      </view>
    </view>
  </view>
</view>
