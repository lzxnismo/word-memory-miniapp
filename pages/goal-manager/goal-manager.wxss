/* pages/goal-manager/goal-manager.wxss */
.container {
  padding: 20rpx;
  background: #f5f5f5;
  min-height: 100vh;
}

.header {
  padding: 30rpx 20rpx;
  background: linear-gradient(135deg, #667eea, #764ba2);
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  color: #fff;
}
.title {
  font-size: 40rpx;
  font-weight: bold;
  display: block;
}
.subtitle {
  font-size: 26rpx;
  opacity: 0.9;
  margin-top: 8rpx;
  display: block;
}

.section {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}
.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}
.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}
.btn-create {
  background: linear-gradient(135deg, #667eea, #764ba2);
  color: #fff;
  border-radius: 40rpx;
  font-size: 24rpx;
}

.goal-card {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  padding: 20rpx;
  background: #f8f9ff;
  border-radius: 12rpx;
  margin-bottom: 12rpx;
}
.goal-type-badge {
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  font-size: 20rpx;
  font-weight: bold;
  whitespace: nowrap;
}
.goal-type-badge.daily {
  background: #e3f2fd;
  color: #1565c0;
}
.goal-type-badge.weekly {
  background: #fce4ec;
  color: #c62828;
}
.goal-type-badge.monthly {
  background: #e8f5e9;
  color: #2e7d32;
}

.goal-info {
  flex: 1;
}
.goal-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 12rpx;
}
.goal-progress {
  display: flex;
  align-items: center;
  gap: 12rpx;
}
.progress-bar {
  flex: 1;
  height: 12rpx;
  background: #e0e0e0;
  border-radius: 6rpx;
  overflow: hidden;
}
.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #667eea, #764ba2);
  border-radius: 6rpx;
  transition: width 0.3s;
}
.progress-text {
  font-size: 22rpx;
  color: #667eea;
  white-space: nowrap;
}
.goal-deadline {
  font-size: 22rpx;
  color: #999;
  margin-top: 8rpx;
  display: block;
}

.completed-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}
.completed-icon {
  font-size: 32rpx;
}
.completed-title {
  flex: 1;
  font-size: 26rpx;
  color: #999;
  text-decoration: line-through;
}
.completed-date {
  font-size: 22rpx;
  color: #ccc;
}

.empty-tip {
  text-align: center;
  padding: 60rpx 0;
}
.tip-icon {
  font-size: 64rpx;
  display: block;
}
.tip-text {
  font-size: 26rpx;
  color: #999;
  margin-top: 12rpx;
}

.dialog-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}
.dialog {
  background: #fff;
  border-radius: 20rpx;
  padding: 40rpx;
  width: 80%;
  max-width: 600rpx;
}
.dialog-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 24rpx;
}
.form-group {
  margin-bottom: 20rpx;
}
.form-label {
  font-size: 26rpx;
  color: #666;
  display: block;
  margin-bottom: 8rpx;
}
.form-input {
  border: 1px solid #e0e0e0;
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
  font-size: 28rpx;
}
.type-selector, .unit-selector {
  display: flex;
  gap: 12rpx;
}
.type-option, .unit-option {
  padding: 12rpx 24rpx;
  border: 1px solid #e0e0e0;
  border-radius: 40rpx;
  font-size: 24rpx;
  color: #666;
}
.type-option.selected, .unit-option.selected {
  background: linear-gradient(135deg, #667eea, #764ba2);
  color: #fff;
  border-color: transparent;
}
.dialog-actions {
  display: flex;
  gap: 20rpx;
  justify-content: flex-end;
  margin-top: 24rpx;
}
.btn-cancel, .btn-confirm {
  font-size: 26rpx;
  padding: 12rpx 32rpx;
  border-radius: 40rpx;
}
.btn-cancel {
  background: #f0f0f0;
  color: #666;
}
.btn-confirm {
  background: linear-gradient(135deg, #667eea, #764ba2);
  color: #fff;
}