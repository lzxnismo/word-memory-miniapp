/* pages/dictation/dictation.wxss */
.container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background-color: #f0f2f5;
}

/* 头部信息 */
.header-section {
  padding: 30rpx;
  background-color: white;
  border-bottom-left-radius: 30rpx;
  border-bottom-right-radius: 30rpx;
}

.header-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.total-count,
.progress-text {
  font-size: 28rpx;
  color: #667eea;
  font-weight: bold;
}

/* 听写区域 */
.quiz-area {
  flex: 1;
  padding: 30rpx;
  display: flex;
  flex-direction: column;
}

.quiz-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 40rpx;
}

.btn-play-audio {
  flex: 1;
  padding: 30rpx 0;
  background: linear-gradient(135deg, #667eea, #764ba2);
  color: white;
  border: none;
  border-radius: 16rpx;
  font-size: 32rpx;
  font-weight: bold;
}

.btn-play-audio::after {
  border: none;
}

.timer-container {
  display: flex;
  align-items: center;
  padding: 20rpx 30rpx;
  background-color: #fff3cd;
  border-radius: 50rpx;
  margin-left: 30rpx;
}

.timer-label {
  font-size: 24rpx;
  color: #856404;
  margin-right: 10rpx;
}

.timer-value {
  font-size: 32rpx;
  font-weight: bold;
  color: #856404;
}

/* 输入框区域 */
.input-section {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 30rpx;
}

.word-input {
  width: 100%;
  height: 180rpx;
  padding: 30rpx;
  font-size: 36rpx;
  line-height: 1.5;
  border: 2rpx solid #ddd;
  border-radius: 16rpx;
  background-color: white;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.input-hints {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.hint-btn {
  padding: 24rpx 30rpx;
  background-color: #e3f2fd;
  color: #1976d2;
  border: 1rpx solid #90caf9;
  border-radius: 12rpx;
  font-size: 28rpx;
}

.hint-btn::after {
  border: none;
}

/* 控制按钮 */
.control-buttons {
  margin-top: 40rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.btn-primary {
  width: 100%;
  padding: 30rpx;
  background: linear-gradient(135deg, #667eea, #764ba2);
  color: white;
  border: none;
  border-radius: 16rpx;
  font-size: 32rpx;
  font-weight: bold;
}

.btn-primary::after {
  border: none;
}

.result-area {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.answer-feedback {
  padding: 30rpx;
  border-radius: 16rpx;
  text-align: center;
  font-size: 32rpx;
  font-weight: bold;
}

.answer-feedback.correct {
  background-color: #d4edda;
  color: #155724;
}

.answer-feedback.wrong {
  background-color: #f8d7da;
  color: #721c24;
}

.feedback-icon {
  font-size: 48rpx;
  margin-right: 10rpx;
}

.correct-answer {
  padding: 30rpx;
  background-color: white;
  border-radius: 16rpx;
  border: 2rpx solid #667eea;
}

.correct-word {
  font-size: 24rpx;
  color: #666;
  margin-right: 10rpx;
}

.correct-spelling {
  font-size: 48rpx;
  font-weight: bold;
  color: #333;
  margin-right: 20rpx;
}

.correct-phonetic {
  font-size: 28rpx;
  color: #999;
  font-family: "Lucida Sans Unicode", sans-serif;
}

.explanation {
  padding: 30rpx;
  background-color: white;
  border-radius: 16rpx;
}

.meaning-label {
  font-size: 24rpx;
  color: #666;
  margin-right: 10rpx;
}

.meaning-text {
  font-size: 28rpx;
  color: #333;
}

.btn-next {
  width: 100%;
  padding: 30rpx;
  background-color: #667eea;
  color: white;
  border: none;
  border-radius: 16rpx;
  font-size: 32rpx;
  font-weight: bold;
}

.btn-next::after {
  border: none;
}

/* 完成页面 */
.completion-screen {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 60rpx;
  text-align: center;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.completion-icon {
  font-size: 120rpx;
  margin-bottom: 40rpx;
}

.completion-title {
  font-size: 48rpx;
  font-weight: bold;
  color: white;
  margin-bottom: 20rpx;
}

.score-display {
  display: flex;
  align-items: baseline;
  justify-content: center;
  margin-bottom: 20rpx;
}

.score-num {
  font-size: 96rpx;
  font-weight: bold;
  color: white;
}

.score-total {
  font-size: 32rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-left: 10rpx;
}

.score-percentage {
  font-size: 40rpx;
  color: #ffd700;
  font-weight: bold;
  margin-bottom: 20rpx;
}

.performance-msg {
  font-size: 32rpx;
  color: rgba(255, 255, 255, 0.9);
  margin-bottom: 60rpx;
  min-height: 80rpx;
}

.action-buttons {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  width: 100%;
  max-width: 400rpx;
}

.btn-primary,
.btn-secondary {
  padding: 30rpx;
  border-radius: 16rpx;
  border: none;
  font-size: 32rpx;
  font-weight: bold;
}

.btn-primary {
  background-color: white;
  color: #667eea;
}

.btn-secondary {
  background-color: transparent;
  color: white;
  border: 2rpx solid white;
}

/* 加载状态 */
.loading-screen {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background-color: white;
}

.loading-icon {
  font-size: 80rpx;
}

.loading-text {
  font-size: 28rpx;
  color: #999;
  margin-top: 30rpx;
}
