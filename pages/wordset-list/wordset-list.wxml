<!-- pages/wordset-list/wordset-list.wxml -->
<view class="container">
  <view class="header">
    <text class="title">📚 单词集</text>
    <text class="subtitle">创建自定义单词集，分组学习更高效</text>
  </view>

  <!-- 创建按钮 -->
  <view class="create-bar">
    <button class="btn-create" bindtap="showCreateDialog">+ 新建单词集</button>
  </view>

  <!-- 单词集列表 -->
  <view class="set-list">
    <view class="set-item" wx:for="{{sets}}" wx:key="id" bindtap="openSet" data-id="{{item.id}}">
      <view class="set-color" style="background-color: {{item.color || '#667eea'}}"></view>
      <view class="set-info">
        <text class="set-name">{{item.name}}</text>
        <text class="set-desc" wx:if="{{item.description}}">{{item.description}}</text>
        <view class="set-stats">
          <text class="stat-text">📝 {{item.word_count}} 词</text>
          <text class="stat-text">🎯 掌握率 {{item.retention_rate}}%</text>
          <text class="stat-text">✍️ 听写率 {{item.dictation_rate}}%</text>
        </view>
      </view>
      <view class="set-arrow">→</view>
    </view>

    <view class="empty-tip" wx:if="{{sets.length === 0}}">
      <text class="tip-icon">📭</text>
      <text class="tip-text">还没有单词集，点击上方按钮创建吧！</text>
    </view>
  </view>

  <!-- 创建对话框 -->
  <view class="dialog-mask" wx:if="{{showCreate}}">
    <view class="dialog">
      <text class="dialog-title">新建单词集</text>
      <input class="dialog-input" placeholder="名称（如：四级高频词）" value="{{newName}}" bindinput="onNameInput" />
      <input class="dialog-input" placeholder="描述（可选）" value="{{newDesc}}" bindinput="onDescInput" />
      <view class="color-picker">
        <text class="color-label">颜色：</text>
        <view class="color-options">
          <view class="color-dot" wx:for="{{colors}}" wx:key="*this" 
            style="background-color: {{item}}" 
            bindtap="selectColor" data-color="{{item}}"
            class="{{newColor === item ? 'selected' : ''}}">
          </view>
        </view>
      </view>
      <view class="dialog-actions">
        <button class="btn-cancel" bindtap="hideCreateDialog">取消</button>
        <button class="btn-confirm" bindtap="createSet">创建</button>
      </view>
    </view>
  </view>
</view>