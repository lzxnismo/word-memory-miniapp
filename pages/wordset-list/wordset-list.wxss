/* pages/wordset-list/wordset-list.wxss */
.container {
  padding: 20rpx;
  background: #f5f5f5;
  min-height: 100vh;
}

.header {
  padding: 30rpx 20rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 16rpx;
  margin-bottom: 20rpx;
}
.title {
  font-size: 40rpx;
  font-weight: bold;
  color: #fff;
  display: block;
}
.subtitle {
  font-size: 26rpx;
  color: rgba(255,255,255,0.8);
  margin-top: 8rpx;
  display: block;
}

.create-bar {
  margin-bottom: 20rpx;
}
.btn-create {
  background: linear-gradient(135deg, #667eea, #764ba2);
  color: #fff;
  border-radius: 40rpx;
  font-size: 28rpx;
}

/* 单词集列表 */
.set-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}
.set-item {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}
.set-color {
  width: 12rpx;
  height: 80rpx;
  border-radius: 6rpx;
  margin-right: 20rpx;
}
.set-info {
  flex: 1;
}
.set-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  display: block;
}
.set-desc {
  font-size: 24rpx;
  color: #999;
  margin-top: 4rpx;
  display: block;
}
.set-stats {
  display: flex;
  gap: 20rpx;
  margin-top: 8rpx;
}
.stat-text {
  font-size: 22rpx;
  color: #888;
}
.set-arrow {
  font-size: 32rpx;
  color: #ccc;
}

/* 空状态 */
.empty-tip {
  text-align: center;
  padding: 100rpx 0;
}
.tip-icon {
  font-size: 80rpx;
  display: block;
}
.tip-text {
  font-size: 28rpx;
  color: #999;
  margin-top: 16rpx;
}

/* 创建对话框 */
.dialog-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}
.dialog {
  background: #fff;
  border-radius: 20rpx;
  padding: 40rpx;
  width: 80%;
  max-width: 600rpx;
}
.dialog-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 24rpx;
}
.dialog-input {
  border: 1px solid #e0e0e0;
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
  font-size: 28rpx;
  margin-bottom: 16rpx;
}
.color-picker {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}
.color-label {
  font-size: 26rpx;
  color: #666;
  margin-right: 16rpx;
}
.color-options {
  display: flex;
  gap: 12rpx;
}
.color-dot {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  border: 3px solid transparent;
}
.color-dot.selected {
  border-color: #333;
}
.dialog-actions {
  display: flex;
  gap: 20rpx;
  justify-content: flex-end;
}
.btn-cancel, .btn-confirm {
  font-size: 26rpx;
  padding: 12rpx 32rpx;
  border-radius: 40rpx;
}
.btn-cancel {
  background: #f0f0f0;
  color: #666;
}
.btn-confirm {
  background: linear-gradient(135deg, #667eea, #764ba2);
  color: #fff;
}