/* pages/words-list/words-list.wxss */
.container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background-color: #f5f7fa;
}

/* 搜索栏区域 */
.search-section {
  padding: 30rpx;
  background-color: white;
  border-bottom-left-radius: 30rpx;
  border-bottom-right-radius: 30rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.search-bar {
  position: relative;
  margin-bottom: 20rpx;
}

.search-icon {
  position: absolute;
  left: 30rpx;
  top: 50%;
  transform: translateY(-50%);
  font-size: 32rpx;
}

.search-input {
  width: 100%;
  height: 80rpx;
  padding: 0 30rpx 0 90rpx;
  font-size: 28rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 40rpx;
  background-color: #f8f9fa;
}

.filter-bar {
  display: flex;
  gap: 16rpx;
  overflow-x: auto;
}

.filter-btn {
  flex-shrink: 0;
  padding: 16rpx 32rpx;
  font-size: 24rpx;
  color: #667eea;
  background-color: #f8f9fa;
  border: 2rpx solid #667eea;
  border-radius: 30rpx;
  transition: all 0.3s;
}

.filter-btn.active {
  background-color: #667eea;
  color: white;
  border-color: #667eea;
}

/* 统计卡片 */
.stats-section {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 20rpx;
  padding: 30rpx;
  background-color: white;
  margin-bottom: 20rpx;
}

.stat-item {
  text-align: center;
  padding: 20rpx 10rpx;
  border-radius: 16rpx;
  background-color: #f8f9fa;
}

.stat-value {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  color: #667eea;
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 20rpx;
  color: #999;
}

/* 单词列表 */
.word-list {
  flex: 1;
  padding: 20rpx;
}

.word-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  margin-bottom: 20rpx;
  background-color: white;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
  cursor: pointer;
}

.word-item:active {
  background-color: #f8f9fa;
}

.word-content {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.word-main {
  display: flex;
  align-items: baseline;
  margin-bottom: 12rpx;
}

.word-en {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  margin-right: 20rpx;
}

.word-phonetic {
  font-size: 28rpx;
  color: #667eea;
  font-family: "Lucida Sans Unicode", sans-serif;
}

.word-meaning {
  font-size: 28rpx;
  color: #666;
  line-height: 1.4;
  margin-bottom: 12rpx;
}

.word-status {
  display: inline-block;
  font-size: 20rpx;
  color: #999;
  padding: 6rpx 16rpx;
  border-radius: 12rpx;
  background-color: #f0f0f0;
}

.word-status.reviewing {
  color: #ffa500;
  background-color: #fff8e7;
}

.word-status.new {
  color: #667eea;
  background-color: #edeefc;
}

.word-actions {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  margin-left: 20rpx;
}

.btn-audio,
.btn-detail {
  width: 80rpx;
  height: 80rpx;
  font-size: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: transparent;
  border: none;
  cursor: pointer;
}

.btn-audio::after,
.btn-detail::after {
  border: none;
}

.empty-tip {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 40rpx;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}

.loading-more {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
  color: #999;
}

.loading-spinner {
  font-size: 32rpx;
  margin-right: 10rpx;
}
