/* pages/wordset-detail/wordset-detail.wxss */
.container {
  background: #f5f5f5;
  min-height: 100vh;
}

.set-header {
  background: linear-gradient(135deg, #667eea, #764ba2);
  padding: 40rpx 30rpx;
  color: #fff;
}
.set-color-bar {
  width: 8rpx;
  height: 60rpx;
  border-radius: 4rpx;
  margin-bottom: 16rpx;
}
.set-name {
  font-size: 36rpx;
  font-weight: bold;
  display: block;
}
.set-desc {
  font-size: 24rpx;
  opacity: 0.9;
  margin-top: 8rpx;
  display: block;
}
.set-stats {
  display: flex;
  gap: 20rpx;
  margin-top: 20rpx;
}
.stat-item {
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  background: rgba(255,255,255,0.2);
  border-radius: 20rpx;
}

.action-bar {
  display: flex;
  gap: 16rpx;
  padding: 20rpx;
  background: #fff;
  margin-bottom: 16rpx;
}
.btn-action {
  flex: 1;
  font-size: 26rpx;
  padding: 16rpx 0;
  border-radius: 40rpx;
}
.btn-delete {
  background: #ffebee;
  color: #e53935;
}

.words-list {
  padding: 0 20rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}
.word-item {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}
.word-main {
  display: flex;
  align-items: baseline;
  gap: 16rpx;
  margin-bottom: 8rpx;
}
.word-en {
  font-size: 34rpx;
  font-weight: bold;
  color: #333;
}
.word-phonetic {
  font-size: 22rpx;
  color: #999;
  font-family: Arial;
}
.word-cn {
  font-size: 28rpx;
  color: #666;
  display: block;
  margin-bottom: 12rpx;
}
.word-meta {
  display: flex;
  gap: 16rpx;
  margin-bottom: 8rpx;
}
.meta-item {
  font-size: 22rpx;
  color: #888;
}
.word-suggestion {
  background: #fff8e1;
  padding: 12rpx 16rpx;
  border-radius: 8rpx;
}
.word-suggestion text {
  font-size: 22rpx;
  color: #ffa000;
}

.empty-tip {
  text-align: center;
  padding: 100rpx 0;
}
.tip-icon {
  font-size: 80rpx;
  display: block;
}
.tip-text {
  font-size: 28rpx;
  color: #999;
  margin-top: 16rpx;
}

.dialog-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}
.dialog {
  background: #fff;
  border-radius: 20rpx;
  padding: 40rpx;
  width: 80%;
  max-width: 600rpx;
}
.dialog-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 24rpx;
}
.search-bar {
  display: flex;
  gap: 12rpx;
  margin-bottom: 24rpx;
}
.search-input {
  flex: 1;
  border: 1px solid #e0e0e0;
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
  font-size: 28rpx;
}
.btn-search {
  background: linear-gradient(135deg, #667eea, #764ba2);
  color: #fff;
  border-radius: 12rpx;
  padding: 16rpx 24rpx;
  font-size: 26rpx;
}
.search-result {
  background: #f8f8f8;
  padding: 24rpx;
  border-radius: 12rpx;
  margin-bottom: 24rpx;
}
.result-word {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  display: block;
}
.result-phonetic {
  font-size: 22rpx;
  color: #999;
  display: block;
}
.result-meaning {
  font-size: 26rpx;
  color: #666;
  margin-top: 8rpx;
  display: block;
}
.not-found {
  font-size: 26rpx;
  color: #999;
  text-align: center;
  display: block;
}
.btn-add {
  background: linear-gradient(135deg, #667eea, #764ba2);
  color: #fff;
  border-radius: 40rpx;
  margin-top: 16rpx;
}
.btn-cancel {
  background: #f0f0f0;
  color: #666;
  border-radius: 40rpx;
  padding: 12rpx 32rpx;
}