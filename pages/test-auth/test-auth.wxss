/* pages/test-auth/test-auth.wxss */
.container {
  padding: 30rpx;
  background: #f5f5f5;
  min-height: 100vh;
}

.test-header {
  text-align: center;
  padding: 40rpx 20rpx;
  background: linear-gradient(135deg, #667eea, #764ba2);
  color: white;
  border-radius: 24rpx;
  margin-bottom: 30rpx;
}

.title {
  font-size: 40rpx;
  font-weight: bold;
  display: block;
  margin-bottom: 10rpx;
}

.subtitle {
  font-size: 24rpx;
  opacity: 0.9;
  display: block;
}

.status-card {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
  background: white;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
  margin-bottom: 30rpx;
}

.status-card.warning {
  background: linear-gradient(135deg, #fff5e6, #ffe0cc);
  border: 2rpx solid #ff9500;
}

.icon {
  font-size: 60rpx;
  margin-right: 20rpx;
}

.label {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  flex: 1;
}

.openid {
  font-size: 24rpx;
  color: #666;
  margin-top: 10rpx;
  font-family: monospace;
}

.tip {
  font-size: 24rpx;
  color: #ff9500;
  display: block;
  margin-top: 10rpx;
}

.test-list {
  background: white;
  border-radius: 20rpx;
  padding: 20rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
}

.test-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.test-item:last-child {
  border-bottom: none;
}

.test-name {
  font-size: 28rpx;
  color: #333;
  flex: 1;
}

.btn-test {
  padding: 16rpx 30rpx;
  border-radius: 12rpx;
  font-size: 24rpx;
  border: none;
  transition: all 0.3s;
  background: #e0e0e0;
  color: #999;
}

.btn-test::after {
  border: none;
}

.btn-test.disabled {
  opacity: 0.6;
}

.btn-success {
  background: linear-gradient(135deg, #51cf66, #40c057);
  color: white;
}

.btn-authorize {
  width: 100%;
  padding: 40rpx;
  background: linear-gradient(135deg, #69db7c, #40c057);
  color: white;
  border-radius: 20rpx;
  font-size: 32rpx;
  font-weight: bold;
  border: none;
  margin-bottom: 20rpx;
  box-shadow: 0 8rpx 20rpx rgba(72, 187, 120, 0.3);
}

.btn-authorize::after {
  border: none;
}

.btn-reset {
  width: 100%;
  padding: 30rpx;
  background: #f0f0f0;
  color: #666;
  border-radius: 20rpx;
  font-size: 28rpx;
  border: none;
}

.btn-reset::after {
  border: none;
}
